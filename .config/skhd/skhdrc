# default mode is a blue border
:: default : borders active_color="gradient(top_left=0xff03f4fc,bottom_right=0xff9003fc)"

### Misc ###

# sleep
hyper - x : osascript -e 'tell application "System Events" to sleep'

# fullscreen
hyper - c : yabai -m window --toggle zoom-fullscreen

### Open Applications ###

# Show Desktop = hyper - u is set natively in settings

# open Finder
hyper - i : open ~/Desktop/

# open Terminal.app
hyper - o : open -na /Applications/Alacritty.app

# open Quick Note = hyper - p is set natively in settings

# open System Settings.app
hyper - 0x21 : open -na /System/Applications/System\ Settings.app

# open zoom (accessibility feature) = hyper - z is set natively in settings

### Windows Management ###

# float/unfloat a window
hyper - g : \
    yabai -m window --toggle float; \
    yabai -m window --toggle border

# focusing windows
hyper - h : yabai -m window --focus west
hyper - j : yabai -m window --focus north
hyper - k : yabai -m window --focus south
hyper - l : yabai -m window --focus east

# moving windows
meh - h : yabai -m window --swap west
meh - j : yabai -m window --swap north
meh - k : yabai -m window --swap south
meh - l : yabai -m window --swap east

# rotate windows
hyper - 0x29 : yabai -m space --rotate 270      # hyper + semicolon

# focus on spaces by number
hyper - 1 : yabai -m space --focus 1
hyper - 2 : yabai -m space --focus 2
hyper - 3 : yabai -m space --focus 3
hyper - 4 : yabai -m space --focus 4
hyper - 5 : yabai -m space --focus 5
hyper - 6 : yabai -m space --focus 6
hyper - 7 : yabai -m space --focus 7
hyper - 8 : yabai -m space --focus 8
hyper - 9 : yabai -m space --focus 9

# move windows between spaces
meh - 1 : yabai -m window --space 1
meh - 2 : yabai -m window --space 2
meh - 3 : yabai -m window --space 3
meh - 4 : yabai -m window --space 4
meh - 5 : yabai -m window --space 5
meh - 6 : yabai -m window --space 6
meh - 7 : yabai -m window --space 7
meh - 8 : yabai -m window --space 8
meh - 9 : yabai -m window --space 9

### Spaces Management ###

# spaces creation/deletion
hyper - m : yabai -m space --create && yabai -m space --focus last
hyper - n : yabai -m space --destroy

# move between spaces
hyper - f : yabai -m space --focus next
hyper - d : yabai -m space --focus prev

# create a new space, move the current window to it and focus it
hyper - h : yabai -m space --create && yabai -m window --space last && yabai -m space --focus last

# defines a new mode 'test' with an on_enter command, that captures keypresses
:: resize @ : borders active_color=0xfff7768e

# switch modes
resize < hyper - v ; default
default < hyper - v ; resize

# resize commands
resize < left : yabai -m window --resize left:-10:0; \
                  yabai -m window --resize right:-10:0
resize < down : yabai -m window --resize bottom:0:10; \
                  yabai -m window --resize top:0:10
resize < up   : yabai -m window --resize top:0:-10; \
                  yabai -m window --resize bottom:0:-10
resize < right : yabai -m window --resize right:10:0; \
                  yabai -m window --resize left:10:0

# balance the window tree using Enter/Return
resize < 0x24 : yabai -m space --balance
